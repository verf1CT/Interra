<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Только app group для обмена данными с виджетом баланса.
	  НЕ добавлять сюда aps-environment, пока аккаунт бесплатный —
	  см. Runner.entitlements и docs/IOS_PUSH_SETUP.md.
	-->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.ru.interra.lkInterra</string>
	</array>
</dict>
</plist>
