# Порт HTTP-сервера
PORT=8080

# Токен администратора для входа в панель рассылки и админ-API.
# Задайте длинную случайную строку.
ADMIN_TOKEN=change-me-to-a-long-random-string

# Путь к service account ключу Firebase (скачивается из консоли Firebase:
# Project settings -> Service accounts -> Generate new private key).
# Если не задан — отправка push отключена, но регистрация устройств и
# админка работают (режим "dry-run", сообщения логируются в консоль).
FIREBASE_SERVICE_ACCOUNT=./serviceAccountKey.json

# Файл базы данных SQLite
DB_PATH=./data/interra.sqlite
